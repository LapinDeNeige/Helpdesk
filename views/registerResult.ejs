<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=0.5"/>
    <link rel="stylesheet" type="text/css" href="../styles/styles.css">
    <link rel="stylesheet" type="text/css" href="../styles/support.css">
    <link rel="shortcut icon" href="/logo.png"/>
    <title>Helpdesk</title>

    <script src="./scripts/result.js"></script>
  </head>
  <body>
    <div class="support-container" style="top:25%">
        <% if(status=='OK') { %>
            <div class="content" style="background-color: white;color:green;">
                <div class="status status-success">
                <h1>User signed up successfully</h1>
                <script>setTimeout(()=>{window.location.href="/login";},5000)   </script>
                </div>
                </div>
            </div>
        <%} else {%>
            <div class="content" style="background-color: white;color:green;">
                <div class="status status-error">
                <h1>Error registering user</h1>
                <script>setTimeout(()=>{window.location.href="/registration";},5000)   </script>
                </div>
            </div>
        <% }%>
    </div>
  </body>
  </html>